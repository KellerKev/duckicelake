# duckicelake configuration file.
#
# Copy to ./duckicelake.toml (or point DUCKICELAKE_CONFIG_FILE at it).
# Every key maps onto the corresponding DUCKICELAKE_* environment variable:
# top-level `key` -> DUCKICELAKE_KEY, `[section] key` -> DUCKICELAKE_SECTION_KEY.
# Precedence: real environment variables > .env > this file.
# Booleans map to the "1"/"0" convention the env flags use.

catalog = "lake"

# Omit the root S3 key pair from REST response configs (default: true).
# Leave true in any deployment relying on governance masking — root keys in
# client hands bypass it in one line. Dev stacks that want the old
# convenience (PyIceberg without vended credentials) set this to false.
suppress_root_creds = true

# Return SET search_path post_attach_sql from the ducklake-credentials
# endpoint so cooperative DuckLake-direct clients get masking transparently
# for unqualified queries (default: true).
transparent_masking = true

# Refuse to start without configured OAuth clients (production safety belt).
#require_auth = true

# PG row-level security for vended DuckLake-direct readers (default: true).
# Per-principal LOGIN roles in the duckicelake_reader group; see OPERATIONS.md
# for the production pg_hba recipe (dev trust-auth can't enforce login).
#rls = true
#reader_group_role = "duckicelake_reader"

# Strict governance: the cooperative (catalog-level) tier ALSO fails closed —
# any governance error on a governed read denies (503) instead of degrading
# to unmasked-with-audit. The file-layer tier + RLS vend always fail closed
# regardless. Trade-off: a governance-sidecar outage takes governed reads
# down with it (default: false).
#governance_fail_closed = true

# File-layer masking (governance Phase 4) tuning.
#masked_retain_snap_dirs = 2       # snap dirs kept per mask-signature
#masked_export_ttl_days = 7        # idle sigs stop being eagerly refreshed
#masked_export_file_size = "256MB" # parquet part size for exports

[pg]
host = "/path/to/repo/.pgsock"   # or a hostname
port = 55432
user = "ducklake"
database = "ducklake"
# password = "…"   # for managed Postgres (RDS/Supabase/Neon/Cloud SQL) using
#                  # scram. Dev uses socket trust auth, so leave it unset.
#                  # Must be conninfo-safe: no spaces, quotes, or backslashes.
#                  # Equivalent env var: DUCKICELAKE_PG_PASSWORD.

[s3]
endpoint = "http://127.0.0.1:9100"
region = "us-east-1"
bucket = "lakehouse"
root_key = "minioadmin"
root_secret = "minioadmin"
path_style = true
prefix = "data/"

# Where STS AssumeRole lives (credential vending).
#   unset      -> the S3 endpoint itself (MinIO co-hosts STS; the default)
#   "aws"      -> https://sts.{region}.amazonaws.com (real AWS, regional)
#   "none"     -> backend has NO STS (Hetzner): REST clients get remote
#                 signing, DuckLake-direct clients use static keys +
#                 generated bucket policies (see OPERATIONS.md)
#   any URL    -> used verbatim (GovCloud, VPC endpoints, LocalStack)
[sts]
#endpoint = "aws"
# Real AWS needs an existing, assumable role; MinIO accepts any string.
#role_arn = "arn:aws:iam::123456789012:role/duckicelake-vend"
# Upper clamp for vended DurationSeconds. AWS also REJECTS values above the
# role's MaxSessionDuration (sts vending retries once at 3600 on that).
#max_duration = 43200

# Hetzner Object Storage (only with [sts] endpoint = "none"):
#[hetzner]
#project_id = "123456"   # project owning the S3 CREDENTIALS (Principal ARNs)

# External base URL of the proxy — becomes `s3.signer.uri` for remote-signing
# clients. Unset: each request's own base URL (fine without a reverse proxy).
#public_url = "https://catalog.example.com"
# Signer authorization cache TTL, seconds (bounds PG load AND revocation lag).
#signer_cache_ttl = 10.0

# S3 gateway — the no-STS "our-own" short-lived credential tier for
# DuckLake-direct DuckDB clients (only meaningful with [sts] endpoint = "none").
# When enabled, ducklake-credentials hands DuckDB an endpoint pointing at this
# proxy plus a minted, scoped, expiring credential; the gateway verifies the
# caller's SigV4, applies per-request governance, re-signs with the root key,
# and forwards to the backend. Off by default (static-key tier stays in place).
#[s3_gateway]
#enabled = true
# The gateway's OWN HMAC key (distinct from the OAuth JWT secret). Required.
#secret = "change-me-gateway-hmac-key"
# Endpoint advertised to clients as `s3.endpoint`. Must resolve, from the
# client's network, to this proxy (path-style S3 rides the same port as the
# catalog API — e.g. an internal address that reaches uvicorn/socat).
#url = "http://10.0.0.3:8181"
# Minted-credential lifetime, seconds (short by design; expiry is the primary
# lifetime bound, governance revocation is still live per request).
#ttl = 900

#[oauth]
#clients = "agent:s3cr3t|ns:analytics:r|agent"
#clients_file = "/etc/duckicelake/clients.json"
#jwt_secret = "change-me"
#ttl_seconds = 3600
#issuer = "duckicelake"

#[log]
#format = "json"    # or "text"
#level = "INFO"
